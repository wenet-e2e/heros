# Required
DASHSCOPE_API_KEY=

# Optional
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_REQUEST_TIMEOUT_MS=60000
HEROS_REALTIME_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
HEROS_REALTIME_MODEL=qwen3.5-omni-plus-realtime
HEROS_REALTIME_VOICE=Cindy
HEROS_REALTIME_INPUT_TRANSCRIPTION_MODEL=gummy-realtime-v1
HEROS_REALTIME_TURN_DETECTION=semantic_vad
HEROS_REALTIME_VAD_THRESHOLD=0.5
HEROS_REALTIME_VAD_PREFIX_PADDING_MS=500
HEROS_REALTIME_VAD_SILENCE_DURATION_MS=800
HEROS_REALTIME_CONNECT_RETRIES=2
HEROS_REALTIME_CONNECT_RETRY_DELAY_MS=500
HEROS_VOICE_INPUT_MODE=half_duplex
HEROS_VOICE_OUTPUT_TAIL_MS=800
HEROS_HANDOFF_POST_FILLER_PAUSE_MS=250
HEROS_STARTUP_GREETING=你好啊，有什么可以帮你？
HEROS_BACKGROUND_MODEL=qwen3.7-plus
HEROS_BACKGROUND_TASK_TIMEOUT_MS=60000
HEROS_TIME_ZONE=Asia/Shanghai
HEROS_DATA_DIR=.heros
HEROS_EVENT_LOG_PATH=.heros/events.ndjson
HEROS_REMINDER_POLL_MS=30000
