# Optional: LLM classifier for chitchat vs intent.
HEROS_LLM_API_KEY=
HEROS_LLM_MODEL=gpt-4.1-mini
HEROS_LLM_BASE_URL=https://api.openai.com/v1/responses

# Optional: override runtime directory for AGENTS.md / SOUL.md / MEMORY.md.
HEROS_AGENT_WORKSPACE_DIR=
# Optional: max tool loop rounds for text-agent entry.
HEROS_AGENT_MAX_TOOL_ROUNDS=6
