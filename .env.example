# Required
DASHSCOPE_API_KEY=

# Optional
HEROS_REALTIME_MODEL=qwen3.5-omni-plus-realtime
HEROS_REALTIME_TURN_DETECTION=semantic_vad
HEROS_REALTIME_CONNECT_RETRIES=2
HEROS_REALTIME_CONNECT_RETRY_DELAY_MS=500
HEROS_BACKGROUND_MODEL=qwen3.7-plus
HEROS_TIME_ZONE=Asia/Shanghai
HEROS_DATA_DIR=.heros
HEROS_EVENT_LOG_PATH=.heros/events.ndjson
HEROS_REMINDER_POLL_MS=30000
